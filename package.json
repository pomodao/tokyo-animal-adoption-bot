{
  "name": "tokyo-animal-adoption-bot",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --pretty false",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "monitor": "node src/cli/run-monitor.ts",
    "test": "find src -name \"*.test.ts\" -print0 | xargs -0 node --test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.58.2"
  }
}
